---
import Layout from '../layouts/Layout.astro';
const IMG = {
  hero: 'https://images.ctfassets.net/drib7o8rcbyf/3SSkmL8U5YBGKCPkJoIdib/07d03a08278a1f3576dc52cdb2ed5e79/CORE_ANCILLARIES_MODULE__STUDIO_PILATES_375x563-min.jpg?fm=webp&fit=fill&w=1920',
  split: 'https://images.ctfassets.net/drib7o8rcbyf/3nHzLEyA0EUbwptegIjvpR/d00dffbc475fe36f129523a6e672b1e6/REGENERATION_MODULE__ICONIC_SPACES_375x563-min.jpg?fm=webp&fit=fill&w=1000',
  split2: 'https://images.ctfassets.net/drib7o8rcbyf/64oMt8msJ0h1l75i0ejdfs/51022d60a8ac8c3915436d1ede080321/CORE_ANCILLARIES_MODULE__PT_375x563-min.jpg?fm=webp&fit=fill&w=1000',
  red: 'https://images.ctfassets.net/drib7o8rcbyf/1bWwZYCr12yWUXuz8WkTc8/48e6bc6818aa55c46721ea5b6cd110ac/Red_Lady_Portrait.jpg?fm=webp&fit=fill&w=1920',
};
---
<Layout
  title="Programme Summit | No Limit Academy"
  description="Le programme Summit — la transformation totale. Conciergerie 24/7, expéditions Explora Project, cercle privé de dirigeants. À partir de 8 000 EUR par mois."
>

<div class="page-hero">
  <div class="page-hero-bg" style={`background-image:url('${IMG.hero}')`}></div>
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content">
    <p class="section-label">Programme</p>
    <h1 class="section-title" style="font-size:clamp(40px,6vw,72px)"><em>Summit</em></h1>
    <p style="font-size:clamp(15px,1.6vw,20px);color:var(--gold);margin-top:16px;font-family:var(--font-mono)">Le plus populaire — À partir de 8 000 EUR / mois</p>
    <p style="font-size:18px;color:var(--gray-light);margin-top:16px;max-width:600px">La transformation totale. Tout Ascent plus conciergerie dédiée, expéditions Explora Project et cercle privé de dirigeants.</p>
  </div>
</div>

<section class="section section-dark">
  <div class="section-center reveal">
    <p class="section-label">Ce qui est inclus</p>
    <h2 class="section-title">Tout Ascent. <em>Et bien plus.</em></h2>
  </div>
  <div class="science-grid reveal">
    <div class="science-card">
      <p class="science-icon">Ascent complet</p>
      <h3>Tout le programme Ascent</h3>
      <p>Les 6 piliers du programme Ascent sont inclus intégralement. Vous bénéficiez de la même infrastructure de base, enrichie.</p>
    </div>
    <div class="science-card">
      <p class="science-icon">Conciergerie</p>
      <h3>Dédiée 24/7</h3>
      <p>Une conciergerie bien-être personnelle disponible à toute heure. Organisation, conseils, coordination avec vos coachs et partenaires.</p>
    </div>
    <div class="science-card">
      <p class="science-icon">Expéditions</p>
      <h3>2 Explora Project / an</h3>
      <p>Deux expéditions transformationnelles par an avec Explora Project. Leadership en conditions extrêmes, nature sauvage, groupe limité.</p>
    </div>
    <div class="science-card">
      <p class="science-icon">Santé avancée</p>
      <h3>Bilan Lucis trimestriel</h3>
      <p>Bilans tous les 3 mois avec diagnostics avancés. Détection précoce, suivi précis des tendances sur l'année.</p>
    </div>
    <div class="science-card">
      <p class="science-icon">Masterclasses</p>
      <h3>Athlètes d'élite</h3>
      <p>Sessions exclusives avec d'anciens athlètes olympiques, champions du monde et figures de la performance de haut niveau.</p>
    </div>
    <div class="science-card">
      <p class="science-icon">Communauté</p>
      <h3>Cercle privé de dirigeants</h3>
      <p>Accès à la communauté privée Summit. Échanges, synergies et connexions entre pairs de même niveau d'exigence.</p>
    </div>
  </div>
</section>

<section class="split reveal">
  <div class="split-img">
    <div class="split-img-bg" style={`background-image:url('${IMG.split}')`}></div>
  </div>
  <div class="split-body">
    <p class="section-label">Explora Project</p>
    <h2 class="section-title">Le leadership se forge <em>dans l'extrême</em></h2>
    <p class="section-desc">En partenariat avec Explora Project, les membres Summit participent à deux expéditions transformationnelles par an. Arctique, désert, haute montagne. Des environnements qui révèlent les leaders.</p>
    <p class="section-desc">Groupes limités à 12 participants. Encadrement par des experts en leadership et des guides de montagne professionnels. Une expérience qui marque pour toujours.</p>
    <a href="/experiences" class="btn btn-ghost btn-arrow">Voir toutes les expériences</a>
  </div>
</section>

<section class="split split-reverse reveal">
  <div class="split-img">
    <div class="split-img-bg" style={`background-image:url('${IMG.split2}')`}></div>
  </div>
  <div class="split-body">
    <p class="section-label">Au-delà</p>
    <h2 class="section-title">Évoluer vers <em>Legacy</em></h2>
    <p class="section-desc">Pour les dirigeants qui veulent l'ultime, Legacy offre un athlète-mentor personnel, des expéditions privées et l'accès aux meilleures cliniques du monde.</p>
    <a href="/legacy" class="btn btn-ghost btn-arrow">Découvrir Legacy</a>
  </div>
</section>

<section class="section section-darker">
  <div class="testimonial reveal">
    <p class="testimonial-quote">« L'expédition en Laponie a transformé ma vision du leadership. Je suis revenu avec une clarté que je n'avais pas depuis 10 ans. »</p>
    <p class="testimonial-author">Membre Summit</p>
    <p class="testimonial-role">PDG, groupe technologique européen</p>
  </div>
</section>

<section class="cta-banner">
  <div class="cta-banner-bg" style={`background-image:url('${IMG.red}')`}></div>
  <div class="cta-banner-content">
    <p class="section-label reveal">Le plus populaire</p>
    <h2 class="section-title reveal">Rejoindre Summit.<br><em>Changer de niveau.</em></h2>
    <p class="section-desc reveal">À partir de 8 000 EUR par mois. Sur candidature uniquement. 50 places par trimestre.</p>
    <div class="reveal" style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap">
      <a href="/candidature" class="btn btn-primary btn-arrow">Postuler pour Summit</a>
      <a href="/programmes" class="btn btn-outline">Comparer les programmes</a>
    </div>
  </div>
</section>

</Layout>
