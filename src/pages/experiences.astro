---
import Layout from '../layouts/Layout.astro';
const IMG = {
  hero: 'https://images.ctfassets.net/drib7o8rcbyf/3nHzLEyA0EUbwptegIjvpR/d00dffbc475fe36f129523a6e672b1e6/REGENERATION_MODULE__ICONIC_SPACES_375x563-min.jpg?fm=webp&fit=fill&w=1920',
  iconic1200: 'https://images.ctfassets.net/drib7o8rcbyf/3nHzLEyA0EUbwptegIjvpR/d00dffbc475fe36f129523a6e672b1e6/REGENERATION_MODULE__ICONIC_SPACES_375x563-min.jpg?fm=webp&fit=fill&w=1200',
  gf800: 'https://images.ctfassets.net/drib7o8rcbyf/7xaVBLqmztmYQGrXBg0pqx/01d2a0130ad7a05585663d9600b437eb/CORE_ANCILLARIES_MODULE__GF_375x563-min.jpg?fm=webp&fit=fill&w=800',
  red1200: 'https://images.ctfassets.net/drib7o8rcbyf/1bWwZYCr12yWUXuz8WkTc8/48e6bc6818aa55c46721ea5b6cd110ac/Red_Lady_Portrait.jpg?fm=webp&fit=fill&w=1200',
  pt1200: 'https://images.ctfassets.net/drib7o8rcbyf/64oMt8msJ0h1l75i0ejdfs/51022d60a8ac8c3915436d1ede080321/CORE_ANCILLARIES_MODULE__PT_375x563-min.jpg?fm=webp&fit=fill&w=1200',
  spa800: 'https://images.ctfassets.net/drib7o8rcbyf/1Z0EStzVUSZJUjkCqHMkol/9c9c7601c4fa6b4532fd2c77803dbe36/REGENERATION_MODULE__SPA_375x563-min.jpg?fm=webp&fit=fill&w=800',
  pilates1200: 'https://images.ctfassets.net/drib7o8rcbyf/3SSkmL8U5YBGKCPkJoIdib/07d03a08278a1f3576dc52cdb2ed5e79/CORE_ANCILLARIES_MODULE__STUDIO_PILATES_375x563-min.jpg?fm=webp&fit=fill&w=1200',
  amenities800: 'https://images.ctfassets.net/drib7o8rcbyf/3jxErqCGFfGDk4HdpTvBhH/40e1d98bddae5be182a0eb5c65e56d59/REGENERATION_MODULE__Amenities_375x563-min.jpg?fm=webp&fit=fill&w=800',
  red: 'https://images.ctfassets.net/drib7o8rcbyf/1bWwZYCr12yWUXuz8WkTc8/48e6bc6818aa55c46721ea5b6cd110ac/Red_Lady_Portrait.jpg?fm=webp&fit=fill&w=1920',
};
---
<Layout
  title="Expériences | No Limit Academy"
  description="Des expéditions transformationnelles et événements exclusifs pour repousser les limites des dirigeants visionnaires."
>

<div class="page-hero">
  <div class="page-hero-bg" style={`background-image:url('${IMG.hero}')`}></div>
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content">
    <p class="section-label">Expériences</p>
    <h1 class="section-title" style="font-size:clamp(40px,6vw,72px)">Au-delà de la<br><em>zone de confort</em></h1>
    <p style="font-size:18px;color:var(--gray-light);margin-top:16px;max-width:600px">Des expéditions transformationnelles et des événements exclusifs conçus pour repousser les limites, forger la résilience et créer des liens entre dirigeants.</p>
  </div>
</div>

<section class="section section-dark">
  <div class="section-center reveal">
    <p class="section-label">Expéditions</p>
    <h2 class="section-title">L'extrême <em>révèle les leaders</em></h2>
    <p class="section-desc">Chaque expédition No Limit Academy est conçue pour sortir les dirigeants de leur zone de confort et les confronter à des défis qui redéfiniront leur vision du leadership.</p>
  </div>
  <div class="experiences reveal">
    <div class="experience">
      <div class="experience-img" style={`background-image:url('${IMG.iconic1200}')`}></div>
      <div class="experience-content">
        <span class="experience-tag">Partenariat Explora Project</span>
        <h3 class="experience-title">Expédition Leadership Arctique</h3>
        <p class="experience-desc">7 jours en Laponie suédoise. Tracking sur glace, aurores boréales et ateliers leadership en conditions extrêmes. Limité à 12 participants. Membres Summit et Legacy.</p>
      </div>
    </div>
    <div class="experience">
      <div class="experience-img" style={`background-image:url('${IMG.gf800}')`}></div>
      <div class="experience-content">
        <span class="experience-tag">Membres Summit et Legacy</span>
        <h3 class="experience-title">Retraite Biohacking Executive</h3>
        <p class="experience-desc">5 jours de diagnostics avancés, cryothérapie, breathwork et optimisation de performance dans un domaine privé.</p>
      </div>
    </div>
    <div class="experience">
      <div class="experience-img" style={`background-image:url('${IMG.red1200}')`}></div>
      <div class="experience-content">
        <span class="experience-tag">Sur invitation uniquement</span>
        <h3 class="experience-title">Le Sommet No Limit</h3>
        <p class="experience-desc">Rassemblement annuel des membres, coachs et athlètes de classe mondiale. Lieu révélé 48 heures avant le départ.</p>
      </div>
    </div>
  </div>
</section>

<section class="section section-darker">
  <div class="experiences reveal">
    <div class="experience">
      <div class="experience-img" style={`background-image:url('${IMG.pt1200}')`}></div>
      <div class="experience-content">
        <span class="experience-tag">Tous membres</span>
        <h3 class="experience-title">Masterclasses Athlètes d'élite</h3>
        <p class="experience-desc">Sessions exclusives avec d'anciens olympiens et champions du monde. Leadership, performance sous pression, résilience mentale.</p>
      </div>
    </div>
    <div class="experience">
      <div class="experience-img" style={`background-image:url('${IMG.spa800}')`}></div>
      <div class="experience-content">
        <span class="experience-tag">Membres Legacy</span>
        <h3 class="experience-title">Expédition privée sur mesure</h3>
        <p class="experience-desc">Une expédition conçue exclusivement pour vous. Destination, défis, encadrement — tout selon vos spécifications et objectifs.</p>
      </div>
    </div>
    <div class="experience">
      <div class="experience-img" style={`background-image:url('${IMG.pilates1200}')`}></div>
      <div class="experience-content">
        <span class="experience-tag">Membres Summit et Legacy</span>
        <h3 class="experience-title">Retraite de Haute Montagne</h3>
        <p class="experience-desc">4 jours dans les Alpes. Altitude, froid, effort physique extrême. Leadership en milieu hostile. Accompagnement par des guides de montagne professionnels.</p>
      </div>
    </div>
  </div>
</section>

<section class="section section-dark">
  <div class="experiences reveal">
    <div class="experience">
      <div class="experience-img" style={`background-image:url('${IMG.amenities800}')`}></div>
      <div class="experience-content">
        <span class="experience-tag">Tous membres</span>
        <h3 class="experience-title">Soirées Cercle Privé</h3>
        <p class="experience-desc">Événements trimestriels réservés aux membres dans des lieux d'exception. Échanges, networking et construction du cercle de confiance.</p>
      </div>
    </div>
    <div class="experience">
      <div class="experience-img" style={`background-image:url('${IMG.iconic1200}')`}></div>
      <div class="experience-content">
        <span class="experience-tag">Partenariat Explora Project</span>
        <h3 class="experience-title">Désert et Silence</h3>
        <p class="experience-desc">5 jours dans le Sahara marocain. Marche, méditation, contemplation. Retrouver la clarté stratégique dans le silence total.</p>
      </div>
    </div>
    <div class="experience">
      <div class="experience-img" style={`background-image:url('${IMG.red1200}')`}></div>
      <div class="experience-content">
        <span class="experience-tag">Sur invitation</span>
        <h3 class="experience-title">Weekend Résilience Executive</h3>
        <p class="experience-desc">48 heures intensives. Défis physiques, ateliers mentaux, coaching collectif. Un weekend qui change une trajectoire professionnelle.</p>
      </div>
    </div>
  </div>
</section>

<section class="cta-banner">
  <div class="cta-banner-bg" style={`background-image:url('${IMG.red}')`}></div>
  <div class="cta-banner-content">
    <p class="section-label reveal">Rejoindre</p>
    <h2 class="section-title reveal">Votre prochaine expédition <em>commence ici</em></h2>
    <p class="section-desc reveal">Les expériences No Limit Academy sont réservées aux membres. Postulez maintenant pour accéder au calendrier complet.</p>
    <div class="reveal" style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap">
      <a href="/candidature" class="btn btn-primary btn-arrow">Postuler comme membre</a>
      <a href="/programmes" class="btn btn-outline">Voir les programmes</a>
    </div>
  </div>
</section>

</Layout>
