---
import Layout from '../layouts/Layout.astro';
const IMG = {
  hero: 'https://images.ctfassets.net/drib7o8rcbyf/3nHzLEyA0EUbwptegIjvpR/d00dffbc475fe36f129523a6e672b1e6/REGENERATION_MODULE__ICONIC_SPACES_375x563-min.jpg?fm=webp&fit=fill&w=1920',
  pt: 'https://images.ctfassets.net/drib7o8rcbyf/64oMt8msJ0h1l75i0ejdfs/51022d60a8ac8c3915436d1ede080321/CORE_ANCILLARIES_MODULE__PT_375x563-min.jpg?fm=webp&fit=fill&w=800',
  spa: 'https://images.ctfassets.net/drib7o8rcbyf/1Z0EStzVUSZJUjkCqHMkol/9c9c7601c4fa6b4532fd2c77803dbe36/REGENERATION_MODULE__SPA_375x563-min.jpg?fm=webp&fit=fill&w=800',
  red: 'https://images.ctfassets.net/drib7o8rcbyf/1bWwZYCr12yWUXuz8WkTc8/48e6bc6818aa55c46721ea5b6cd110ac/Red_Lady_Portrait.jpg?fm=webp&fit=fill&w=1920',
};
---
<Layout
  title="Programmes | No Limit Academy"
  description="Trois niveaux d'adhésion pour votre transformation : Ascent, Summit et Legacy. Choisissez votre voie vers la performance absolue."
>

<div class="page-hero">
  <div class="page-hero-bg" style={`background-image:url('${IMG.hero}')`}></div>
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content">
    <p class="section-label">Niveaux d'adhésion</p>
    <h1 class="section-title" style="font-size:clamp(40px,6vw,72px)">Trois voies vers la <em>performance absolue</em></h1>
    <p style="font-size:18px;color:var(--gray-light);margin-top:16px;max-width:600px">Chaque niveau est un engagement envers votre meilleur vous. Choisissez l'intensité qui correspond à votre ambition.</p>
  </div>
</div>

<section class="section section-dark">
  <div class="tiers reveal">
    <div class="tier">
      <h3 class="tier-name">Ascent</h3>
      <p class="tier-price">À partir de 2 500 EUR / mois</p>
      <p class="tier-desc">Les fondations. Un coaching d'élite régulier et un suivi santé pour construire votre socle de performance.</p>
      <ul class="tier-features">
        <li>3 séances hebdomadaires avec coach élite certifié</li>
        <li>Pack connecté inclus (bracelet + bague connectés au CRM NLA)</li>
        <li>Bilan Lucis semestriel (180+ biomarqueurs)</li>
        <li>Plan personnalisé nutrition, sommeil et récupération</li>
        <li>Tableau de bord performance avec suivi KPIs</li>
        <li>Séance mensuelle de performance mentale</li>
      </ul>
      <a href="/ascent" class="btn btn-outline btn-arrow">En savoir plus</a>
    </div>
    <div class="tier tier-featured">
      <h3 class="tier-name">Summit</h3>
      <p class="tier-price">À partir de 8 000 EUR / mois</p>
      <p class="tier-desc">La transformation. Tout Ascent plus conciergerie dédiée, expéditions et cercle privé de dirigeants.</p>
      <ul class="tier-features">
        <li>Tout le programme Ascent inclus</li>
        <li>Conciergerie bien-être dédiée 24/7</li>
        <li>2 expéditions Explora Project par an</li>
        <li>Bilan Lucis trimestriel + diagnostics avancés</li>
        <li>Masterclasses exclusives avec athlètes d'élite</li>
        <li>Communauté privée de dirigeants</li>
      </ul>
      <a href="/summit" class="btn btn-primary btn-arrow">En savoir plus</a>
    </div>
    <div class="tier">
      <h3 class="tier-name">Legacy</h3>
      <p class="tier-price">À partir de 25 000 EUR / mois</p>
      <p class="tier-desc">L'ultime. Un programme sur mesure avec votre propre athlète-mentor, des expéditions privées et l'accès aux meilleures cliniques du monde.</p>
      <ul class="tier-features">
        <li>Tout le programme Summit inclus</li>
        <li>Athlète-mentor personnel (ancien olympien ou équivalent)</li>
        <li>Expéditions privées conçues pour vous</li>
        <li>Programme longévité avec suivi génomique et épigénétique</li>
        <li>Réseau mondial de cliniques partenaires</li>
        <li>Événements sur invitation dans des lieux tenus secrets</li>
      </ul>
      <a href="/legacy" class="btn btn-outline btn-arrow">En savoir plus</a>
    </div>
  </div>
</section>

<section class="section section-darker">
  <div class="stats reveal">
    <div class="stat"><div class="stat-number">2 500€</div><div class="stat-label">Programme Ascent / mois</div></div>
    <div class="stat"><div class="stat-number">8 000€</div><div class="stat-label">Programme Summit / mois</div></div>
    <div class="stat"><div class="stat-number">25 000€</div><div class="stat-label">Programme Legacy / mois</div></div>
    <div class="stat"><div class="stat-number">100%</div><div class="stat-label">Déductible entreprise</div></div>
  </div>
</section>

<section class="split reveal">
  <div class="split-img">
    <div class="split-img-bg" style={`background-image:url('${IMG.pt}')`}></div>
  </div>
  <div class="split-body">
    <p class="section-label">Financement</p>
    <h2 class="section-title">Votre entreprise <em>finance votre performance</em></h2>
    <p class="section-desc">No Limit Academy s'intègre dans les dispositifs légaux de santé au travail, QVCT et formation professionnelle. L'adhésion peut être intégralement prise en charge par votre entreprise.</p>
    <a href="/financement" class="btn btn-ghost btn-arrow">En savoir plus</a>
  </div>
</section>

<section class="split split-reverse reveal">
  <div class="split-img">
    <div class="split-img-bg" style={`background-image:url('${IMG.spa}')`}></div>
  </div>
  <div class="split-body">
    <p class="section-label">Pack connecté</p>
    <h2 class="section-title">Bracelet + Bague.<br><em>CRM No Limit.</em></h2>
    <p class="section-desc">Chaque adhésion inclut un pack bracelet et bague connectés, intégrés directement au CRM No Limit Academy. Vos données biométriques alimentent votre tableau de bord en temps réel, accessible par votre coach à chaque séance.</p>
    <a href="/science" class="btn btn-ghost btn-arrow">Découvrir la science</a>
  </div>
</section>

<section class="cta-banner">
  <div class="cta-banner-bg" style={`background-image:url('${IMG.red}')`}></div>
  <div class="cta-banner-content">
    <p class="section-label reveal">Accès limité</p>
    <h2 class="section-title reveal">50 places par trimestre. <em>Sur candidature.</em></h2>
    <p class="section-desc reveal">No Limit Academy n'est pas un service. C'est un engagement entre vous et les meilleurs coachs du monde.</p>
    <div class="reveal" style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap">
      <a href="/candidature" class="btn btn-primary btn-arrow">Postuler maintenant</a>
    </div>
  </div>
</section>

</Layout>
