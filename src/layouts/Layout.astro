---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = "No Limit Academy | L'académie d'élite pour dirigeants",
  description = "No Limit Academy — coaching d'élite, science préventive et expériences transformationnelles pour dirigeants visionnaires.",
} = Astro.props;
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style is:global>
/* ─── Variables ─── */
:root {
  /* Fonds */
  --bg-primary: #faf8f4;
  --bg-alt:     #f0ece4;
  --bg-card:    #ffffff;
  --bg-dark:    #0a0a0a;

  /* Or */
  --gold:       #c9a96e;
  --gold-hover: #b8963e;

  /* Textes */
  --text-heading: #0a0a0a;
  --text-body:    #555555;
  --text-light:   #999999;
  --text-on-dark: #f5f0eb;

  /* Bordures */
  --border:       #e5e0d8;
  --border-hover: rgba(201,169,110,0.3);

  /* Typo */
  --font-serif: 'Playfair Display', Georgia, serif;
  --font-sans:  'DM Sans', system-ui, sans-serif;
  --font-mono:  'Space Mono', monospace;

  /* Mise en page */
  --nav-h:  72px;
  --pad-x:  clamp(24px, 5vw, 80px);
  --pad-y:  clamp(80px, 12vh, 140px);
}

/* ─── Reset & base ─── */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
::selection { background: var(--gold); color: var(--bg-dark); }
html { scroll-behavior: smooth; }
body { background: var(--bg-primary); color: var(--text-heading); font-family: var(--font-sans); font-weight: 300; line-height: 1.7; overflow-x: hidden; -webkit-font-smoothing: antialiased; }
img { display: block; max-width: 100%; }
a { color: inherit; text-decoration: none; }

/* ─── Typographie ─── */
h1, h2, h3, h4 { font-family: var(--font-serif); font-weight: 500; line-height: 1.2; letter-spacing: -0.01em; color: var(--text-heading); }
h1 em, h2 em, h3 em, .hero-title em, .section-title em { font-family: var(--font-serif); font-style: italic; font-weight: 400; color: var(--gold); }
.label { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); margin-bottom: 16px; display: block; }
.section-title { font-family: var(--font-serif); font-size: clamp(32px, 4.5vw, 56px); font-weight: 500; line-height: 1.15; margin-bottom: 24px; color: var(--text-heading); }
.section-desc { font-size: 16px; font-weight: 300; color: var(--text-body); line-height: 1.75; max-width: 540px; margin-bottom: 40px; }

/* ─── Boutons ─── */
.btn { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; padding: 14px 32px; transition: all 0.3s; border: none; cursor: pointer; }
.btn-gold { background: var(--gold); color: var(--bg-dark); }
.btn-gold:hover { background: var(--gold-hover); }
.btn-outline { border: 1px solid rgba(10,10,10,0.3); color: var(--text-heading); background: transparent; }
.btn-outline:hover { border-color: var(--gold); color: var(--gold); }
.btn-outline-light { border: 1px solid rgba(245,240,235,0.3); color: var(--text-on-dark); background: transparent; }
.btn-outline-light:hover { border-color: var(--gold); color: var(--gold); }
.btn-ghost { color: var(--gold); padding: 14px 0; background: transparent; border: none; }
.btn-ghost:hover { color: var(--gold-hover); }
.btn-ghost-dark { color: var(--text-heading); padding: 14px 0; background: transparent; border: none; }
.btn-ghost-dark:hover { color: var(--gold); }
.btn-arrow::after { content: '→'; transition: transform 0.3s; }
.btn-arrow:hover::after { transform: translateX(4px); }

/* ─── Nav (fond clair) ─── */
.nav { position: fixed; top: 0; left: 0; width: 100%; z-index: 1000; height: var(--nav-h); padding: 0 var(--pad-x); display: flex; align-items: center; justify-content: space-between; background: rgba(250,248,244,0.94); backdrop-filter: blur(20px); border-bottom: 1px solid var(--border); }
.nav-logo { font-family: var(--font-sans); font-size: 15px; font-weight: 400; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-heading); }
.nav-logo span { color: var(--gold); }
.nav-links { display: flex; align-items: center; gap: 36px; }
.nav-links a { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-light); transition: color 0.3s; }
.nav-links a:hover, .nav-links a.active { color: var(--text-heading); }
.nav-cta { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; padding: 9px 22px; border: 1px solid var(--gold); color: var(--gold); transition: all 0.3s; }
.nav-cta:hover { background: var(--gold); color: var(--bg-dark); }
.nav-hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; }
.nav-hamburger span { width: 22px; height: 1px; background: var(--text-heading); display: block; transition: all 0.3s; }
.nav-mobile { display: none; position: fixed; top: var(--nav-h); left: 0; width: 100%; background: var(--bg-primary); padding: 32px var(--pad-x); border-bottom: 1px solid var(--border); z-index: 999; }
.nav-mobile.open { display: flex; flex-direction: column; gap: 20px; }
.nav-mobile a { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-body); padding: 8px 0; border-bottom: 1px solid var(--border); }

/* ─── Sections (fond clair) ─── */
.section { padding: var(--pad-y) var(--pad-x); }
.section-light { background: var(--bg-primary); }
.section-alt { background: var(--bg-alt); }
/* Alias rétrocompatibilité — pages utilisent encore .section-dark */
.section-dark { background: var(--bg-primary); }
.section-center { text-align: center; }
.section-center .section-desc { margin-left: auto; margin-right: auto; }

/* ─── Hero plein écran (reste sombre : vidéo) ─── */
.hero { position: relative; height: 100vh; min-height: 700px; display: flex; align-items: center; justify-content: center; overflow: hidden; background: var(--bg-dark); }
.hero-bg { position: absolute; inset: 0; background-size: cover; background-position: center; filter: brightness(0.28); }
.hero-video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; filter: brightness(0.3) contrast(1.1); }
.hero-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(10,10,10,0.4) 0%, rgba(10,10,10,0.1) 50%, rgba(10,10,10,0.85) 100%); }
.hero-content { position: relative; z-index: 2; text-align: center; max-width: 860px; padding: 0 24px; }
.hero-label { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); margin-bottom: 28px; opacity: 0; animation: fadeUp 1s 0.3s forwards; }
.hero-title { font-family: var(--font-serif); font-size: clamp(42px, 6.5vw, 80px); font-weight: 500; line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 28px; opacity: 0; animation: fadeUp 1s 0.55s forwards; color: var(--text-on-dark); }
.hero-title em { color: var(--gold); }
.hero-sub { font-size: clamp(15px, 1.5vw, 17px); font-weight: 300; color: rgba(245,240,235,0.65); max-width: 520px; margin: 0 auto 52px; opacity: 0; animation: fadeUp 1s 0.8s forwards; line-height: 1.7; }
.hero-scroll { position: absolute; bottom: 36px; left: 50%; transform: translateX(-50%); z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 8px; opacity: 0; animation: fadeUp 1s 1.3s forwards; }
.hero-scroll span { font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(245,240,235,0.4); }
.hero-scroll-line { width: 1px; height: 36px; background: linear-gradient(to bottom, var(--gold), transparent); animation: scrollPulse 2s ease-in-out infinite; }

/* ─── Page hero (pages internes — reste sombre) ─── */
.page-hero { position: relative; height: 60vh; min-height: 460px; display: flex; align-items: flex-end; padding: clamp(40px,6vw,80px) var(--pad-x); overflow: hidden; background: var(--bg-dark); }
.page-hero-bg { position: absolute; inset: 0; background-size: cover; background-position: center; filter: brightness(0.3); }
.page-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(10,10,10,0.2) 0%, rgba(10,10,10,0.8) 100%); }
.page-hero-content { position: relative; z-index: 2; max-width: 760px; }
.page-hero-content h1 { font-size: clamp(38px, 5vw, 64px); color: var(--text-on-dark); }
.page-hero-content h1 em { color: var(--gold); }
.page-hero-content .label { color: var(--gold); }
.page-hero-content p { color: rgba(245,240,235,0.65); }

/* ─── Portes d'entrée (fond clair, texte noir) ─── */
.doors { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--border); }
.door { position: relative; padding: 48px 36px; background: var(--bg-card); transition: background 0.4s; cursor: pointer; display: flex; flex-direction: column; gap: 20px; text-decoration: none; color: var(--text-heading); }
.door:hover { background: rgba(201,169,110,0.07); }
.door-num { font-family: var(--font-mono); font-size: 10px; color: var(--text-light); letter-spacing: 0.15em; }
.door-title { font-family: var(--font-serif); font-size: clamp(20px, 2vw, 26px); font-weight: 500; line-height: 1.2; color: var(--text-heading); }
.door-sub { font-size: 13px; color: var(--text-body); font-weight: 300; line-height: 1.6; }
.door-arrow { font-family: var(--font-mono); font-size: 10px; color: var(--gold); letter-spacing: 0.1em; margin-top: auto; transition: transform 0.3s; }
.door:hover .door-arrow { transform: translateX(6px); }

/* ─── Split ─── */
.split { display: grid; grid-template-columns: 1fr 1fr; min-height: 580px; }
.split-reverse { direction: rtl; }
.split-reverse > * { direction: ltr; }
.split-img { position: relative; overflow: hidden; min-height: 480px; }
.split-img-bg { position: absolute; inset: 0; background-size: cover; background-position: center; transition: transform 0.8s ease; }
.split:hover .split-img-bg { transform: scale(1.03); }
.split-body { display: flex; flex-direction: column; justify-content: center; padding: clamp(40px, 6vw, 100px); background: var(--bg-primary); }
.split-body.alt { background: var(--bg-alt); }

/* ─── Programmes / Tiers (fond blanc, texte noir) ─── */
.tiers { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); margin-top: 60px; }
.tier { background: var(--bg-card); padding: 52px 40px; position: relative; transition: box-shadow 0.4s; }
.tier:hover { box-shadow: 0 0 0 1px var(--gold); z-index: 1; }
.tier-featured { background: var(--bg-card); }
.tier-featured::before { content: 'Le plus populaire'; position: absolute; top: 0; left: 50%; transform: translate(-50%, -50%); font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase; padding: 6px 18px; background: var(--gold); color: var(--bg-dark); white-space: nowrap; }
.tier-label { font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); margin-bottom: 16px; }
.tier-name { font-family: var(--font-serif); font-size: 32px; font-weight: 500; margin-bottom: 8px; color: var(--text-heading); }
.tier-price { font-family: var(--font-mono); font-size: 12px; color: var(--text-light); letter-spacing: 0.05em; margin-bottom: 28px; padding-bottom: 28px; border-bottom: 1px solid var(--border); }
.tier-desc { font-size: 14px; color: var(--text-body); line-height: 1.65; margin-bottom: 28px; font-weight: 300; }
.tier-list { list-style: none; margin-bottom: 40px; }
.tier-list li { font-size: 13px; font-weight: 300; color: var(--text-body); padding: 9px 0; border-bottom: 1px solid var(--border); display: flex; align-items: flex-start; gap: 12px; line-height: 1.5; }
.tier-list li::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: var(--gold); flex-shrink: 0; margin-top: 6px; }
.tier .btn { width: 100%; justify-content: center; }

/* ─── CORTEX dashboard mock (reste sombre intentionnellement) ─── */
.cortex-db { background: #111; border: 1px solid #222; max-width: 480px; font-family: var(--font-mono); }
.cortex-db-bar { display: flex; align-items: center; justify-content: space-between; padding: 12px 18px; border-bottom: 1px solid #222; }
.cortex-db-brand { font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); }
.cortex-db-user { font-size: 10px; color: #666; letter-spacing: 0.05em; }
.cortex-db-dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #4ade80; margin-right: 6px; }
.cortex-db-metrics { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: #222; }
.cortex-metric { background: #111; padding: 18px; }
.cortex-metric-lbl { font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: #666; margin-bottom: 8px; }
.cortex-metric-val { font-size: 24px; color: #f5f0eb; line-height: 1; margin-bottom: 10px; }
.cortex-metric-val span { font-size: 11px; color: #666; }
.cortex-bar-wrap { height: 2px; background: #222; border-radius: 1px; margin-bottom: 8px; }
.cortex-bar-fill { height: 100%; background: var(--gold); border-radius: 1px; }
.cortex-metric-trend { font-size: 10px; }
.cortex-metric-trend.up { color: #4ade80; }
.cortex-metric-trend.neutral { color: #666; }
.cortex-db-insight { padding: 16px 18px; border-top: 1px solid #222; }
.cortex-db-insight strong { display: block; font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); margin-bottom: 6px; }
.cortex-db-insight p { font-size: 11px; color: #888; line-height: 1.55; }

/* ─── Cartes 3 colonnes (fond blanc) ─── */
.cards-3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; background: var(--border); margin-top: 56px; }
.card { background: var(--bg-card); padding: 40px 32px; transition: box-shadow 0.3s; }
.card:hover { box-shadow: 0 0 0 1px var(--gold); z-index: 1; }
.card-icon { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); margin-bottom: 20px; }
.card h3 { font-family: var(--font-serif); font-size: clamp(20px,2vw,24px); font-weight: 500; margin-bottom: 12px; color: var(--text-heading); }
.card p { font-size: 14px; color: var(--text-body); line-height: 1.65; font-weight: 300; }

/* ─── Stats (fond sable) ─── */
.stats { display: grid; grid-template-columns: repeat(4,1fr); gap: 1px; background: var(--border); }
.stat { background: var(--bg-alt); padding: 48px 32px; text-align: center; }
.stat-n { font-family: var(--font-serif); font-size: clamp(36px,4vw,52px); font-weight: 400; color: var(--gold); margin-bottom: 8px; }
.stat-l { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-light); }

/* ─── Témoignage ─── */
.testimonial { max-width: 760px; margin: 0 auto; text-align: center; padding: 80px 24px; }
.testimonial blockquote { font-family: var(--font-serif); font-size: clamp(22px,2.8vw,32px); font-weight: 400; font-style: italic; line-height: 1.45; color: var(--text-heading); margin-bottom: 32px; }
.testimonial cite { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); font-style: normal; }
.testimonial-role { font-size: 13px; color: var(--text-light); margin-top: 6px; }

/* ─── Bandeau CTA (fond sombre — rythme visuel) ─── */
.cta-band { position: relative; padding: 120px var(--pad-x); text-align: center; overflow: hidden; background: var(--bg-dark); }
.cta-band-bg { position: absolute; inset: 0; background-size: cover; background-position: center; filter: brightness(0.2); }
.cta-band-inner { position: relative; z-index: 2; max-width: 860px; margin-left: auto; margin-right: auto; display: flex; flex-direction: column; align-items: center; }
.cta-band .section-title { color: var(--text-on-dark); margin-bottom: 20px; width: 100%; }
.cta-band .section-title em { color: var(--gold); }
.cta-band .section-desc { color: rgba(245,240,235,0.6); margin: 0 auto 40px; text-align: center; }
.cta-band .label { color: var(--gold); }
.cta-band .btn-outline { border-color: rgba(245,240,235,0.25); color: var(--text-on-dark); }
.cta-band .btn-outline:hover { border-color: var(--gold); color: var(--gold); }
/* ─── Groupe de boutons centré (hors cta-band) ─── */
.btns-center { display: flex; justify-content: center; align-items: center; gap: 16px; flex-wrap: wrap; width: 100%; }

/* ─── Expériences ─── */
.exp-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 1px; background: var(--border); margin-top: 56px; }
.exp-card { position: relative; min-height: 420px; overflow: hidden; }
.exp-card-bg { position: absolute; inset: 0; background-size: cover; background-position: center; filter: brightness(0.35); transition: all 0.6s; }
.exp-card:hover .exp-card-bg { filter: brightness(0.25); transform: scale(1.04); }
.exp-card-body { position: relative; z-index: 2; height: 100%; padding: 40px; display: flex; flex-direction: column; justify-content: flex-end; }
.exp-tag { font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }
.exp-title { font-family: var(--font-serif); font-size: clamp(22px,2.5vw,30px); font-weight: 500; margin-bottom: 10px; color: var(--text-on-dark); }
.exp-desc { font-size: 13px; color: rgba(245,240,235,0.65); line-height: 1.6; font-weight: 300; max-width: 380px; }
.exp-price { font-family: var(--font-mono); font-size: 11px; color: var(--gold); margin-top: 12px; }

/* ─── Footer (reste sombre) ─── */
.footer { background: var(--bg-dark); padding: 80px var(--pad-x) 40px; border-top: 1px solid rgba(201,169,110,0.08); }
.footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 60px; margin-bottom: 60px; }
.footer-brand { font-family: var(--font-sans); font-size: 14px; font-weight: 400; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 12px; color: var(--text-on-dark); }
.footer-brand span { color: var(--gold); }
.footer-tagline { font-size: 13px; color: #666; line-height: 1.65; max-width: 280px; font-weight: 300; }
.footer-col-title { font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); margin-bottom: 20px; }
.footer-col a { display: block; font-size: 13px; color: #666; margin-bottom: 10px; transition: color 0.3s; font-weight: 300; }
.footer-col a:hover { color: var(--text-on-dark); }
.footer-bottom { display: flex; justify-content: space-between; align-items: center; padding-top: 28px; border-top: 1px solid #1a1a1a; font-family: var(--font-mono); font-size: 10px; color: #444; letter-spacing: 0.05em; }

/* ─── Animations ─── */
@keyframes fadeUp { from { opacity:0; transform:translateY(28px); } to { opacity:1; transform:translateY(0); } }
@keyframes scrollPulse { 0%,100% { opacity:0.3; } 50% { opacity:1; } }
.reveal { opacity:0; transform:translateY(36px); transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1); }
.reveal.visible { opacity:1; transform:translateY(0); }

/* ─── Responsive ─── */
@media (max-width: 900px) {
  .doors { grid-template-columns: 1fr 1fr; }
  .tiers { grid-template-columns: 1fr; }
  .split { grid-template-columns: 1fr; }
  .split-reverse { direction: ltr; }
  .cards-3 { grid-template-columns: 1fr; }
  .stats { grid-template-columns: 1fr 1fr; }
  .exp-grid { grid-template-columns: 1fr; }
  .footer-grid { grid-template-columns: 1fr 1fr; gap: 40px; }
}
@media (max-width: 640px) {
  .nav-links { display: none; }
  .nav-cta { display: none; }
  .nav-hamburger { display: flex; }
  .doors { grid-template-columns: 1fr; }
  .stats { grid-template-columns: 1fr; }
  .footer-grid { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<nav class="nav">
  <a href="/" class="nav-logo">No Limit <span>Academy</span></a>
  <div class="nav-links">
    <a href="/membre" class={currentPath.startsWith('/membre') ? 'active' : ''}>Membres</a>
    <a href="/coach" class={currentPath.startsWith('/coach') ? 'active' : ''}>Coachs</a>
    <a href="/investir" class={currentPath.startsWith('/investir') ? 'active' : ''}>Investir</a>
    <a href="/partenaire" class={currentPath.startsWith('/partenaire') ? 'active' : ''}>Partenaire</a>
    <a href="mailto:apply@no-limit-academy.com" class="nav-cta">Postuler</a>
  </div>
  <div class="nav-hamburger" id="nav-ham">
    <span></span>
    <span></span>
    <span></span>
  </div>
</nav>

<div class="nav-mobile" id="nav-mobile">
  <a href="/membre">Membres</a>
  <a href="/coach">Coachs</a>
  <a href="/investir">Investir</a>
  <a href="/partenaire">Partenaire</a>
  <a href="mailto:apply@no-limit-academy.com">Postuler</a>
</div>

<slot />

<footer class="footer">
  <div class="footer-grid">
    <div>
      <div class="footer-brand">No Limit <span>Academy</span></div>
