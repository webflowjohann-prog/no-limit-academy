---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = "NATICS Lab | L'intelligence santé de précision",
  description = "NATICS Lab — l'intelligence santé de précision. 137 biomarqueurs. 6 agents IA. Un score unique.",
} = Astro.props;
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description}>
<!-- Open Graph -->
<meta property="og:type" content="website">
<meta property="og:site_name" content="NATICS Lab">
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:image" content="https://natics-lab.netlify.app/images/og-nla.png">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:url" content={`https://natics-lab.netlify.app${Astro.url.pathname}`}>
<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content="https://natics-lab.netlify.app/images/og-nla.png">
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style is:global>
/* ─── Variables ─── */
:root {
  --bg:        #0D0D0D;
  --surface:   #141414;
  --card:      #1A1A1A;
  --card-hi:   #262626;
  --border:    rgba(255,255,255,0.06);
  --border-hi: rgba(201,169,110,0.25);
  --gold:      #c9a96e;
  --gold-hover:#b8963e;
  --gold-glow: rgba(201,169,110,0.18);
  --t1:        #FFFFFF;
  --t2:        #D9D9D9;
  --t3:        #A6A6A6;
  --t4:        #595959;
  --gray:      #A6A6A6;

  /* Alias rétrocompatibilité */
  --bg-primary:   #0D0D0D;
  --bg-alt:       #141414;
  --bg-card:      #1A1A1A;
  --bg-dark:      #0D0D0D;
  --text-heading: #FFFFFF;
  --text-body:    #A6A6A6;
  --text-light:   #595959;
  --text-on-dark: #FFFFFF;
  --border-hover: rgba(201,169,110,0.25);

  --font-serif: 'Playfair Display', Georgia, serif;
  --font-sans:  'DM Sans', system-ui, sans-serif;
  --font-mono:  'Space Mono', monospace;

  --nav-h: 72px;
  --pad-x: clamp(24px, 5vw, 80px);
  --pad-y: clamp(80px, 12vh, 140px);
  --r:     20px;
  --r-sm:  12px;
}

/* ─── Reset & base ─── */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
::selection { background: var(--gold); color: var(--bg); }
html { scroll-behavior: smooth; background: var(--bg); }
body { background: var(--bg); color: var(--t2); font-family: var(--font-sans); font-weight: 300; line-height: 1.7; overflow-x: hidden; -webkit-font-smoothing: antialiased; }
img { display: block; max-width: 100%; }
a { color: inherit; text-decoration: none; }

/* ─── Typographie ─── */
h1, h2, h3, h4 { font-family: var(--font-serif); font-weight: 400; line-height: 1.2; letter-spacing: -0.01em; color: var(--t1); }
h1 em, h2 em, h3 em, .hero-title em, .section-title em { font-family: var(--font-serif); font-style: italic; font-weight: 400; color: var(--gold); }
.label { font-family: var(--font-sans); font-weight: 500; font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--t4); margin-bottom: 20px; display: block; }
.section-title { font-family: var(--font-serif); font-size: clamp(28px, 4.5vw, 48px); font-weight: 400; line-height: 1.15; margin-bottom: 20px; color: var(--t1); }
.section-desc { font-size: clamp(14px, 1.8vw, 17px); font-weight: 300; color: var(--t3); line-height: 1.8; max-width: 560px; margin-bottom: 40px; }

/* ─── Boutons ─── */
.btn { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-sans); font-weight: 500; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; padding: 14px 32px; transition: all 0.3s; border: none; cursor: pointer; border-radius: var(--r-sm); }
.btn-gold { background: var(--gold); color: var(--bg); box-shadow: 0 4px 24px var(--gold-glow); }
.btn-gold:hover { background: var(--gold-hover); transform: translateY(-1px); box-shadow: 0 8px 32px var(--gold-glow); }
.btn-outline { border: 1px solid rgba(255,255,255,0.15); color: var(--t1); background: transparent; }
.btn-outline:hover { border-color: var(--gold); color: var(--gold); }
.btn-outline-light { border: 1px solid rgba(255,255,255,0.15); color: var(--t1); background: transparent; }
.btn-outline-light:hover { border-color: var(--gold); color: var(--gold); }
.btn-ghost { color: var(--gold); padding: 14px 0; background: transparent; border: none; font-family: var(--font-sans); font-weight: 500; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; }
.btn-ghost:hover { color: var(--gold-hover); }
.btn-ghost-dark { color: var(--t1); padding: 14px 0; background: transparent; border: none; }
.btn-ghost-dark:hover { color: var(--gold); }
.btn-arrow::after { content: '→'; transition: transform 0.3s; }
.btn-arrow:hover::after { transform: translateX(4px); }
.cta { display: inline-block; padding: 14px 40px; background: var(--gold); color: var(--bg); font-family: var(--font-sans); font-size: 13px; font-weight: 500; letter-spacing: 0.08em; border-radius: var(--r-sm); border: none; cursor: pointer; transition: all 0.3s; box-shadow: 0 4px 24px var(--gold-glow); text-align: center; }
.cta:hover { background: var(--gold-hover); transform: translateY(-1px); box-shadow: 0 8px 32px var(--gold-glow); }
.cta-ghost { background: transparent; border: 1px solid rgba(201,169,110,0.3); color: var(--gold); }
.cta-ghost:hover { border-color: var(--gold); background: rgba(201,169,110,0.06); }

/* ─── Nav glassmorphism dark ─── */
.nav { position: fixed; top: 0; left: 0; width: 100%; z-index: 1000; height: var(--nav-h); padding: 0 var(--pad-x); display: flex; align-items: center; justify-content: space-between; background: rgba(13,13,13,0.9); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px); border-bottom: 1px solid var(--border); }
.nav-logo { font-family: var(--font-sans); font-size: 14px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--t1); }
.nav-logo span { color: var(--gold); }
.nav-links { display: flex; align-items: center; gap: 36px; }
.nav-links a { font-family: var(--font-sans); font-weight: 500; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--t4); transition: color 0.3s; }
.nav-links a:hover, .nav-links a.active { color: var(--t1); }
.nav-cta { font-family: var(--font-sans); font-weight: 500; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; padding: 9px 22px; border: 1px solid rgba(201,169,110,0.4); color: var(--gold); transition: all 0.3s; border-radius: var(--r-sm); }
.nav-cta:hover { background: var(--gold); color: var(--bg); }
.nav-hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; }
.nav-hamburger span { width: 22px; height: 1px; background: var(--t1); display: block; transition: all 0.3s; }
.nav-mobile { display: none; position: fixed; top: var(--nav-h); left: 0; width: 100%; background: rgba(13,13,13,0.97); backdrop-filter: blur(24px); padding: 32px var(--pad-x); border-bottom: 1px solid var(--border); z-index: 999; }
.nav-mobile.open { display: flex; flex-direction: column; gap: 20px; }
.nav-mobile a { font-family: var(--font-sans); font-weight: 500; font-size: 12px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--t3); padding: 8px 0; border-bottom: 1px solid var(--border); }

/* ─── Sections ─── */
.section { padding: var(--pad-y) var(--pad-x); }
.section-light { background: var(--bg); }
.section-alt { background: var(--surface); }
.section-dark { background: var(--bg); }
.section-center { text-align: center; }
.section-center .section-desc { margin-left: auto; margin-right: auto; }

/* ─── Hero plein écran ─── */
.hero { position: relative; height: 100vh; min-height: 700px; display: flex; align-items: center; justify-content: center; overflow: hidden; background: var(--bg); }
.hero-video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
.hero-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(13,13,13,0.3) 0%, rgba(13,13,13,0.6) 60%, rgba(13,13,13,0.95) 100%); }
.hero-content { position: relative; z-index: 2; text-align: center; max-width: 700px; padding: 0 24px; }
.hero-label { font-family: var(--font-sans); font-weight: 500; font-size: 9px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); margin-bottom: 28px; opacity: 0; animation: fadeUp 1s 0.3s forwards; display: block; }
.hero-title { font-family: var(--font-serif); font-size: clamp(36px, 7vw, 64px); font-weight: 400; line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 24px; opacity: 0; animation: fadeUp 1s 0.55s forwards; color: var(--t1); }
.hero-title em { color: var(--gold); }
.hero-sub { font-size: clamp(14px, 2vw, 18px); font-weight: 300; color: var(--t3); max-width: 520px; margin: 0 auto 48px; opacity: 0; animation: fadeUp 1s 0.8s forwards; line-height: 1.7; }
.hero-scroll { position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%); z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 8px; opacity: 0; animation: fadeUp 1s 1.3s forwards; }
.hero-scroll span { font-family: var(--font-sans); font-weight: 500; font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--t4); }
.hero-scroll-line { width: 1px; height: 36px; background: linear-gradient(to bottom, var(--gold), transparent); animation: scrollPulse 2s ease-in-out infinite; }

/* ─── Page hero (pages internes) ─── */
.page-hero { position: relative; height: 60vh; min-height: 460px; display: flex; align-items: flex-end; padding: clamp(40px,6vw,80px) var(--pad-x); overflow: hidden; background: var(--bg); }
.page-hero-bg { position: absolute; inset: 0; background-size: cover; background-position: center; filter: brightness(0.25); }
.page-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(13,13,13,0.2) 0%, rgba(13,13,13,0.85) 100%); }
.page-hero-content { position: relative; z-index: 2; max-width: 760px; }
.page-hero-content h1 { font-size: clamp(32px, 5vw, 56px); color: var(--t1); }
.page-hero-content h1 em { color: var(--gold); }
.page-hero-content .label { color: var(--gold); }
.page-hero-content p { color: var(--t3); }

/* ─── Portes d'entrée ─── */
.doors { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--border); }
.door { position: relative; padding: 48px 36px; background: var(--surface); transition: background 0.4s; cursor: pointer; display: flex; flex-direction: column; gap: 20px; text-decoration: none; color: var(--t1); }
.door:hover { background: var(--card); }
.door-num { font-family: var(--font-sans); font-weight: 500; font-size: 9px; color: var(--t4); letter-spacing: 0.15em; }
.door-title { font-family: var(--font-serif); font-size: clamp(18px, 2vw, 22px); font-weight: 400; line-height: 1.2; color: var(--t1); }
.door-sub { font-size: 13px; color: var(--t3); font-weight: 300; line-height: 1.6; }
.door-arrow { font-family: var(--font-sans); font-weight: 500; font-size: 10px; color: var(--gold); letter-spacing: 0.1em; margin-top: auto; transition: transform 0.3s; }
.door:hover .door-arrow { transform: translateX(6px); }

/* ─── Split ─── */
.split { display: grid; grid-template-columns: 1fr 1fr; min-height: 580px; }
.split-reverse { direction: rtl; }
.split-reverse > * { direction: ltr; }
.split-img { position: relative; overflow: hidden; min-height: 480px; }
.split-img-bg { position: absolute; inset: 0; background-size: cover; background-position: center; filter: brightness(0.5) grayscale(20%); transition: transform 0.8s ease; }
.split:hover .split-img-bg { transform: scale(1.03); }
.split-body { display: flex; flex-direction: column; justify-content: center; padding: clamp(40px, 6vw, 100px); background: var(--bg); }
.split-body.alt { background: var(--surface); }

/* ─── Tiers (programmes) ─── */
.tiers { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 60px; }
.tier { background: rgba(38,38,38,0.4); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); padding: 32px; border-radius: var(--r); border: 1px solid var(--border); position: relative; transition: all 0.3s; }
.tier:hover { border-color: var(--border-hi); transform: translateY(-2px); }
.tier-featured { border-color: rgba(201,169,110,0.25); box-shadow: 0 0 40px var(--gold-glow); }
.tier-featured::before { content: 'Recommandé'; position: absolute; top: -1px; right: 24px; font-family: var(--font-sans); font-weight: 500; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; padding: 6px 14px; background: var(--gold); color: var(--bg); border-radius: 0 0 8px 8px; }
.tier-label { font-family: var(--font-sans); font-weight: 500; font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--t4); margin-bottom: 16px; }
.tier-name { font-family: var(--font-serif); font-size: 28px; font-weight: 400; margin-bottom: 8px; color: var(--t1); }
.tier-price { font-family: var(--font-serif); font-size: 18px; font-weight: 300; color: var(--t1); margin-bottom: 28px; padding-bottom: 20px; border-bottom: 1px solid var(--border); }
.tier-featured .tier-price { color: var(--gold); }
.tier-desc { font-size: 13px; color: var(--t3); line-height: 1.65; margin-bottom: 24px; font-weight: 300; }
.tier-list { list-style: none; margin-bottom: 32px; }
.tier-list li { font-size: 12px; font-weight: 300; color: var(--t3); padding: 7px 0; border-bottom: 1px solid rgba(255,255,255,0.03); display: flex; align-items: flex-start; gap: 12px; line-height: 1.5; }
.tier-list li::before { content: '—'; color: var(--gold); flex-shrink: 0; }
.tier .btn { width: 100%; justify-content: center; }

/* ─── Tiers 2 colonnes ─── */
.tiers-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 60px; max-width: 860px; margin-left: auto; margin-right: auto; }

/* ─── CORTEX dashboard (intentionnellement sombre) ─── */
.cortex-db { background: #0a0a0a; border: 1px solid rgba(201,169,110,0.15); max-width: 480px; width: 100%; font-family: var(--font-mono); border-radius: var(--r); overflow: hidden; }
.cortex-db-bar { display: flex; align-items: center; justify-content: space-between; padding: 12px 18px; border-bottom: 1px solid rgba(255,255,255,0.04); }
.cortex-db-brand { font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); }
.cortex-db-user { font-size: 10px; color: var(--t4); letter-spacing: 0.05em; }
.cortex-db-dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #4ade80; margin-right: 6px; }
.cortex-db-metrics { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: rgba(255,255,255,0.04); }
.cortex-metric { background: #0a0a0a; padding: 16px; }
.cortex-metric-lbl { font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--t4); margin-bottom: 8px; }
.cortex-metric-val { font-size: 22px; color: var(--t1); line-height: 1; margin-bottom: 8px; }
.cortex-metric-val span { font-size: 10px; color: var(--t4); }
.cortex-bar-wrap { height: 2px; background: rgba(255,255,255,0.06); border-radius: 1px; margin-bottom: 6px; }
.cortex-bar-fill { height: 100%; background: var(--gold); border-radius: 1px; }
.cortex-metric-trend { font-size: 10px; }
.cortex-metric-trend.up { color: #4ade80; }
.cortex-metric-trend.neutral { color: var(--t4); }
.cortex-db-insight { padding: 14px 18px; border-top: 1px solid rgba(255,255,255,0.04); }
.cortex-db-insight strong { display: block; font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); margin-bottom: 6px; }
.cortex-db-insight p { font-size: 11px; color: var(--t4); line-height: 1.55; }

/* ─── Cartes 3 colonnes ─── */
.cards-3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; margin-top: 56px; }
.card { background: var(--card); padding: 36px 28px; border-radius: var(--r); border: 1px solid var(--border); transition: all 0.3s; }
.card:hover { border-color: rgba(201,169,110,0.2); transform: translateY(-2px); }
.card-icon { font-family: var(--font-sans); font-weight: 500; font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); margin-bottom: 20px; }
.card h3 { font-family: var(--font-serif); font-size: clamp(18px,1.8vw,22px); font-weight: 400; margin-bottom: 12px; color: var(--t1); }
.card p { font-size: 13px; color: var(--t3); line-height: 1.65; font-weight: 300; }

/* ─── Stats ─── */
.stats { display: grid; grid-template-columns: repeat(4,1fr); gap: 1px; background: var(--border); }
.stat { background: var(--surface); padding: 48px 32px; text-align: center; }
.stat-n { font-family: var(--font-serif); font-size: clamp(32px,4vw,48px); font-weight: 300; color: var(--gold); margin-bottom: 8px; }
.stat-l { font-family: var(--font-sans); font-weight: 500; font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--t4); }

/* ─── Témoignage ─── */
.testimonial { max-width: 760px; margin: 0 auto; text-align: center; padding: 80px 24px; }
.testimonial blockquote { font-family: var(--font-serif); font-size: clamp(20px,2.8vw,28px); font-weight: 400; font-style: italic; line-height: 1.5; color: var(--t1); margin-bottom: 32px; }
.testimonial cite { font-family: var(--font-sans); font-weight: 500; font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); font-style: normal; }
.testimonial-role { font-size: 12px; color: var(--t4); margin-top: 6px; }

/* ─── Bandeau CTA ─── */
.cta-band { position: relative; padding: 120px var(--pad-x); text-align: center; overflow: hidden; background: var(--bg); }
.cta-band-bg { position: absolute; inset: 0; background-size: cover; background-position: center; filter: brightness(0.15); }
.cta-band-inner { position: relative; z-index: 2; max-width: 860px; margin-left: auto; margin-right: auto; display: flex; flex-direction: column; align-items: center; }
.cta-band .section-title { color: var(--t1); margin-bottom: 20px; width: 100%; }
.cta-band .section-title em { color: var(--gold); }
.cta-band .section-desc { color: var(--t3); margin: 0 auto 40px; text-align: center; }
.cta-band .label { color: var(--gold); }
.cta-band .btn-outline { border-color: rgba(255,255,255,0.15); color: var(--t1); }
.cta-band .btn-outline:hover { border-color: var(--gold); color: var(--gold); }
.btns-center { display: flex; justify-content: center; align-items: center; gap: 16px; flex-wrap: wrap; width: 100%; }

/* ─── Séparateur or ─── */
.sep { width: 60px; height: 1px; background: var(--gold); margin: 28px 0; opacity: 0.4; }
.sep-center { margin: 28px auto; }

/* ─── Agents CORTEX ─── */
.agents-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px,1fr)); gap: 16px; margin-top: 40px; }
.agent-card { position: relative; overflow: hidden; border-radius: var(--r); border: 1px solid var(--border); background: var(--card); transition: all 0.4s cubic-bezier(0.4,0,0.2,1); cursor: pointer; }
.agent-card:hover { border-color: var(--gold-glow); transform: translateY(-4px); box-shadow: 0 16px 48px rgba(0,0,0,0.5); }
.agent-img { height: 200px; overflow: hidden; }
.agent-img img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(100%) contrast(1.1); transition: all 0.6s; }
.agent-card:hover .agent-img img { filter: grayscale(80%) contrast(1.05); transform: scale(1.04); }
.agent-body { padding: 24px; }
.agent-name { font-family: var(--font-serif); font-size: 20px; font-weight: 400; color: var(--t1); margin-bottom: 4px; }
.agent-role { font-size: 10px; color: var(--gold); letter-spacing: 0.12em; font-weight: 500; text-transform: uppercase; margin-bottom: 10px; }
.agent-desc { font-size: 12px; color: var(--t3); line-height: 1.6; font-weight: 300; }

/* ─── Video section ─── */
.video-wrap { position: relative; max-width: 800px; margin: 40px auto 0; border-radius: var(--r); overflow: hidden; border: 1px solid var(--border); background: #000; aspect-ratio: 16/9; }
.video-wrap video { width: 100%; height: 100%; object-fit: cover; }
.video-play { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.35); cursor: pointer; transition: background 0.3s; }
.video-play:hover { background: rgba(0,0,0,0.2); }
.video-play-btn { width: 64px; height: 64px; border-radius: 50%; border: 1px solid var(--gold); display: flex; align-items: center; justify-content: center; transition: all 0.3s; box-shadow: 0 0 32px var(--gold-glow); }
.video-play-btn svg { width: 20px; height: 20px; fill: var(--gold); margin-left: 3px; }
.video-play:hover .video-play-btn { transform: scale(1.08); box-shadow: 0 0 48px var(--gold-glow); }
.video-quote { margin-top: 32px; font-family: var(--font-serif); font-style: italic; font-size: clamp(16px,2.5vw,22px); color: var(--gold); line-height: 1.6; max-width: 600px; margin-left: auto; margin-right: auto; text-align: center; }
.video-attr { font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--t4); margin-top: 12px; font-style: normal; font-family: var(--font-sans); font-weight: 500; text-align: center; }

/* ─── Steps ─── */
.steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px,1fr)); gap: 0; margin-top: 48px; border: 1px solid var(--border); border-radius: var(--r); overflow: hidden; }
.step { padding: 36px 28px; border-right: 1px solid var(--border); text-align: center; background: var(--card); }
.step:last-child { border-right: none; }
.step-num { font-family: var(--font-serif); font-size: 48px; font-weight: 300; color: var(--gold); line-height: 1; margin-bottom: 16px; }
.step-title { font-size: 14px; color: var(--t1); font-weight: 400; margin-bottom: 8px; }
.step-desc { font-size: 12px; color: var(--t3); font-weight: 300; line-height: 1.6; }

/* ─── CORTEX Score ─── */
.csw { display: flex; align-items: center; gap: 40px; flex-wrap: wrap; justify-content: center; }
.csw-circle { position: relative; width: 160px; height: 160px; flex-shrink: 0; }
.csw-circle svg { display: block; }
.csw-inner { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.csw-num { font-family: var(--font-serif); font-size: 52px; font-weight: 300; color: var(--gold); line-height: 1; }
.csw-sub { font-family: var(--font-sans); font-weight: 500; font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-top: 4px; }
.csw-levels { display: flex; flex-direction: column; gap: 2px; }
.csw-level { display: flex; align-items: center; justify-content: space-between; gap: 24px; padding: 10px 14px; border-left: 2px solid rgba(255,255,255,0.04); min-width: 180px; }
.csw-level.csw-current { border-left-color: var(--gold); background: rgba(201,169,110,0.04); }
.csw-level-name { font-family: var(--font-sans); font-weight: 500; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--t4); }
.csw-level.csw-current .csw-level-name { color: var(--gold); }
.csw-level-range { font-size: 10px; color: rgba(255,255,255,0.15); }
.csw-level.csw-current .csw-level-range { color: var(--t4); }

/* Score bars (landing page style) */
.score-section { display: flex; align-items: center; gap: 48px; flex-wrap: wrap; justify-content: center; }
.score-ring-wrap { position: relative; width: 200px; height: 200px; flex-shrink: 0; }
.score-ring-wrap svg { transform: rotate(-90deg); }
.score-center { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.score-center .num { font-family: var(--font-serif); font-size: 52px; font-weight: 300; color: var(--gold); }
.score-center .lbl { font-family: var(--font-sans); font-weight: 500; font-size: 9px; letter-spacing: 0.2em; color: var(--gold); margin-top: 2px; text-transform: uppercase; }
.score-bars { flex: 1; min-width: 240px; }
.score-bar { margin-bottom: 14px; }
.score-bar-header { display: flex; justify-content: space-between; margin-bottom: 4px; }
.score-bar-name { font-size: 11px; color: var(--t3); }
.score-bar-val { font-size: 11px; color: var(--t1); font-weight: 500; }
.score-bar-track { height: 3px; background: rgba(255,255,255,0.06); border-radius: 2px; }
.score-bar-fill { height: 100%; background: var(--gold); border-radius: 2px; }

/* ─── Partenaires ─── */
.partners-logos { display: flex; flex-wrap: wrap; gap: 32px; align-items: center; justify-content: center; margin-top: 40px; opacity: 0.3; }
.partners-logos span { font-family: var(--font-sans); font-size: 13px; font-weight: 500; letter-spacing: 0.12em; color: var(--t2); text-transform: uppercase; }

/* ─── Expériences ─── */
.exp-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 16px; margin-top: 56px; }
.exp-card { position: relative; min-height: 380px; overflow: hidden; border-radius: var(--r); }
.exp-card-bg { position: absolute; inset: 0; background-size: cover; background-position: center; filter: brightness(0.3) grayscale(20%); transition: all 0.6s; }
.exp-card:hover .exp-card-bg { filter: brightness(0.2); transform: scale(1.04); }
.exp-card-body { position: relative; z-index: 2; height: 100%; padding: 36px; display: flex; flex-direction: column; justify-content: flex-end; }
.exp-tag { font-family: var(--font-sans); font-weight: 500; font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 10px; }
.exp-title { font-family: var(--font-serif); font-size: clamp(20px,2.5vw,26px); font-weight: 400; margin-bottom: 10px; color: var(--t1); }
.exp-desc { font-size: 12px; color: rgba(255,255,255,0.6); line-height: 1.6; font-weight: 300; max-width: 360px; }
.exp-price { font-family: var(--font-sans); font-weight: 500; font-size: 11px; color: var(--gold); margin-top: 12px; letter-spacing: 0.08em; }
.exp-hero { position: relative; height: 50vh; min-height: 320px; border-radius: var(--r); overflow: hidden; margin-top: 40px; }
.exp-hero img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(100%); }
.exp-hero-overlay { position: absolute; inset: 0; background: linear-gradient(transparent 30%, rgba(13,13,13,0.9)); }
.exp-hero-content { position: absolute; bottom: 32px; left: 32px; right: 32px; }
.exp-drops { display: flex; gap: 12px; margin-top: 20px; flex-wrap: wrap; }
.exp-drop { padding: 10px 20px; background: rgba(38,38,38,0.7); backdrop-filter: blur(16px); border: 1px solid var(--border); border-radius: var(--r-sm); font-size: 12px; color: var(--t2); font-weight: 300; }
.exp-drop strong { color: var(--gold); font-weight: 400; }

/* ─── Validation biométrique ─── */
.valid-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; margin-top: 56px; }
.valid-card { background: var(--card); padding: 36px 28px; border-radius: var(--r); border: 1px solid var(--border); }
.valid-icon { font-size: 13px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--t4); margin-bottom: 16px; font-family: var(--font-sans); font-weight: 500; }
.valid-status { font-family: var(--font-sans); font-weight: 500; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 16px; }
.valid-status.green { color: #4ade80; }
.valid-status.amber { color: #fbbf24; }
.valid-status.red { color: #f87171; }
.valid-card h3 { font-family: var(--font-serif); font-size: clamp(16px,1.6vw,20px); font-weight: 400; margin-bottom: 10px; color: var(--t1); }
.valid-card p { font-size: 13px; color: var(--t3); line-height: 1.65; font-weight: 300; }

/* ─── Fondateurs ─── */
.founders-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; max-width: 960px; margin: 48px auto 0; }
.founder-expand-btn { display: none; color: var(--gold); font-family: var(--font-sans); font-weight: 500; font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; margin-top: 12px; background: none; border: none; padding: 0; }
.founder-bio-short { display: block; }
.founder-bio-long { display: block; }

/* ─── Grilles étapes & phases ─── */
.steps-grid-top { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; margin-top: 56px; }
.steps-grid-bottom { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 16px; max-width: calc(66.666%); }
.phases-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; margin-top: 40px; }

/* ─── Pricing cards (homepage) ─── */
.pricing-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 40px; max-width: 800px; margin-left: auto; margin-right: auto; }
.pricing-card { padding: 32px; border-radius: var(--r); border: 1px solid var(--border); background: rgba(38,38,38,0.4); backdrop-filter: blur(16px); position: relative; transition: all 0.3s; }
.pricing-card.featured { border-color: rgba(201,169,110,0.25); box-shadow: 0 0 40px var(--gold-glow); }
.pricing-badge { position: absolute; top: -1px; right: 24px; background: var(--gold); color: var(--bg); font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; padding: 6px 14px; border-radius: 0 0 8px 8px; font-weight: 500; font-family: var(--font-sans); }
.pricing-label { font-family: var(--font-sans); font-weight: 500; font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--t4); margin-bottom: 8px; }
.pricing-price { font-family: var(--font-serif); font-size: 28px; font-weight: 300; color: var(--t1); margin-bottom: 4px; }
.pricing-card.featured .pricing-price { color: var(--gold); }
.pricing-period { font-size: 11px; color: var(--t4); margin-bottom: 20px; }
.pricing-features { list-style: none; margin-bottom: 24px; }
.pricing-features li { font-size: 12px; color: var(--t3); font-weight: 300; padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,0.03); }
.pricing-features li::before { content: "—"; color: var(--gold); margin-right: 10px; }

/* ─── Concept section ─── */
.concept { text-align: center; padding: clamp(80px,12vw,160px) var(--pad-x); }
.concept p { font-size: clamp(18px,3vw,28px); font-weight: 300; line-height: 2; color: var(--t2); }
.concept em { font-family: var(--font-serif); font-style: italic; color: var(--gold); }

/* ─── Footer ─── */
.footer { background: var(--bg); padding: 60px var(--pad-x) 40px; border-top: 1px solid var(--border); }
.footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 60px; margin-bottom: 48px; }
.footer-brand { font-family: var(--font-sans); font-size: 13px; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 12px; color: var(--t1); }
.footer-brand span { color: var(--gold); }
.footer-tagline { font-size: 12px; color: var(--t4); line-height: 1.65; max-width: 280px; font-weight: 300; }
.footer-col-title { font-family: var(--font-sans); font-weight: 500; font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); margin-bottom: 20px; }
.footer-col a { display: block; font-size: 12px; color: var(--t4); margin-bottom: 10px; transition: color 0.3s; font-weight: 300; }
.footer-col a:hover { color: var(--t1); }
.footer-bottom { display: flex; justify-content: space-between; align-items: center; padding-top: 24px; border-top: 1px solid var(--border); font-family: var(--font-sans); font-weight: 500; font-size: 9px; color: var(--t4); letter-spacing: 0.05em; }
.footer-disclaimer { font-size: 9px; color: rgba(255,255,255,0.15); line-height: 1.8; max-width: 560px; margin: 12px auto 0; text-align: center; }

/* ─── Animations ─── */
@keyframes fadeUp { from { opacity:0; transform:translateY(28px); } to { opacity:1; transform:translateY(0); } }
@keyframes scrollPulse { 0%,100% { opacity:0.3; } 50% { opacity:1; } }
.reveal { opacity:0; transform:translateY(30px); transition: opacity 0.8s ease, transform 0.8s ease; }
.reveal.visible { opacity:1; transform:translateY(0); }

/* ─── Responsive ─── */
@media (max-width: 900px) {
  .doors { grid-template-columns: 1fr 1fr; }
  .tiers { grid-template-columns: 1fr; }
  .tiers-2 { grid-template-columns: 1fr; max-width: 100%; }
  .split { grid-template-columns: 1fr; }
  .split-reverse { direction: ltr; }
  .cards-3 { grid-template-columns: 1fr; }
  .stats { grid-template-columns: 1fr 1fr; }
  .exp-grid { grid-template-columns: 1fr; }
  .footer-grid { grid-template-columns: 1fr 1fr; gap: 40px; }
  .steps-grid-top, .steps-grid-bottom { display: flex; flex-direction: column; max-width: 100%; }
  .phases-grid { display: flex; flex-direction: column; }
  .founders-grid { display: flex; flex-direction: column; max-width: 100%; }
  .valid-grid { grid-template-columns: 1fr; }
  .pricing-grid { grid-template-columns: 1fr; max-width: 100%; }
  .agents-grid { grid-template-columns: 1fr; }
  .steps { grid-template-columns: 1fr; }
  .step { border-right: none; border-bottom: 1px solid var(--border); }
  .step:last-child { border-bottom: none; }
  .founder-bio-long { display: none; }
  .founder-bio-short { display: block; }
  .founder-expand-btn { display: inline-block; }
}
@media (min-width: 901px) {
  .founder-bio-short { display: none; }
  .founder-bio-long { display: block; }
  .founder-expand-btn { display: none; }
}
@media (max-width: 640px) {
  .nav-links { display: none; }
  .nav-cta { display: none; }
  .nav-hamburger { display: flex; }
  .doors { grid-template-columns: 1fr; }
  .stats { grid-template-columns: 1fr; }
  .footer-grid { grid-template-columns: 1fr; }
}
</style>
</head>
