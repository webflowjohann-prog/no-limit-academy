---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'No Limit Academy | Coaching d\'Elite pour Dirigeants Visionnaires',
  description = 'No Limit Academy connecte les meilleurs coachs avec les dirigeants visionnaires. Sante preventive, experiences transformationnelles et communaute de leaders.',
} = Astro.props;
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style is:global>
:root{--black:#0a0a0a;--black-light:#111;--black-card:#141414;--white:#f5f0eb;--gold:#c9a96e;--gold-light:#dfc089;--gold-dark:#a8883f;--gray:#6b6b6b;--gray-light:#999;--gray-dark:#2a2a2a;--gray-border:#222;--font-display:'Outfit',sans-serif;--font-body:'DM Sans',system-ui,sans-serif;--font-mono:'Space Mono',monospace;--nav-height:80px;--section-pad:clamp(80px,12vh,160px)}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}::selection{background:var(--gold);color:var(--black)}html{scroll-behavior:smooth}body{background:var(--black);color:var(--white);font-family:var(--font-body);font-weight:300;line-height:1.7;overflow-x:hidden;-webkit-font-smoothing:antialiased}img{display:block;max-width:100%;height:auto}a{color:inherit;text-decoration:none}button{cursor:pointer;border:none;background:none;font-family:inherit}

/* NAV */
.nav{position:fixed;top:0;left:0;width:100%;z-index:1000;padding:0 clamp(24px,4vw,60px);height:var(--nav-height);display:flex;align-items:center;justify-content:space-between;background:rgba(10,10,10,.85);backdrop-filter:blur(20px);border-bottom:1px solid rgba(201,169,110,.08)}.nav-logo{font-family:var(--font-display);font-size:clamp(16px,2vw,22px);font-weight:500;letter-spacing:.15em;text-transform:uppercase}.nav-logo span{color:var(--gold)}.nav-links{display:flex;gap:clamp(16px,2.5vw,40px);align-items:center}.nav-links a{font-size:12px;font-weight:400;letter-spacing:.12em;text-transform:uppercase;color:var(--gray-light);transition:color .3s;position:relative}.nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:1px;background:var(--gold);transition:width .3s}.nav-links a:hover,.nav-links a.active{color:var(--white)}.nav-links a:hover::after,.nav-links a.active::after{width:100%}.nav-cta{font-size:11px;font-weight:500;letter-spacing:.15em;text-transform:uppercase;padding:10px 24px;border:1px solid var(--gold);color:var(--gold) !important;transition:all .3s}.nav-cta:hover{background:var(--gold);color:var(--black) !important}.nav-hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer}.nav-hamburger span{width:24px;height:1px;background:var(--white);transition:all .3s}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:10px;font-family:var(--font-body);font-size:12px;font-weight:500;letter-spacing:.15em;text-transform:uppercase;padding:15px 36px;transition:all .4s}.btn-primary{background:var(--gold);color:var(--black)}.btn-primary:hover{background:var(--gold-light)}.btn-outline{border:1px solid rgba(255,255,255,.2);color:var(--white)}.btn-outline:hover{border-color:var(--gold);color:var(--gold)}.btn-ghost{color:var(--gold);padding:15px 0}.btn-ghost:hover{color:var(--gold-light)}.btn-arrow::after{content:'\2192';transition:transform .3s}.btn-arrow:hover::after{transform:translateX(4px)}

/* SECTIONS */
.section{padding:var(--section-pad) clamp(24px,5vw,80px)}.section-dark{background:var(--black)}.section-darker{background:var(--black-light)}.section-label{font-family:var(--font-mono);font-size:11px;letter-spacing:.35em;text-transform:uppercase;color:var(--gold);margin-bottom:20px}.section-title{font-family:var(--font-display);font-size:clamp(32px,5vw,60px);font-weight:700;line-height:1.1;letter-spacing:-.01em;margin-bottom:20px}
h1 em,h2 em,.hero-title em,.section-title em{font-family:'Cormorant Garamond',serif;font-style:italic;font-weight:300;text-transform:none;color:var(--gold)}.section-desc{font-size:16px;font-weight:300;color:var(--gray-light);max-width:560px;margin-bottom:48px}.section-center{text-align:center}.section-center .section-desc{margin-left:auto;margin-right:auto}

/* HERO */
.hero{position:relative;height:100vh;min-height:700px;display:flex;align-items:center;justify-content:center;overflow:hidden}.hero-bg{position:absolute;inset:0;background-size:cover;background-position:center;filter:brightness(.3) contrast(1.1);transform:scale(1.05);animation:heroZoom 20s ease-in-out infinite alternate}@keyframes heroZoom{from{transform:scale(1.05)}to{transform:scale(1.12)}}.hero-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(10,10,10,.5) 0%,rgba(10,10,10,.05) 40%,rgba(10,10,10,.8) 100%)}.hero-content{position:relative;z-index:2;text-align:center;max-width:900px;padding:0 24px}.hero-label{font-family:var(--font-mono);font-size:11px;letter-spacing:.35em;text-transform:uppercase;color:var(--gold);margin-bottom:32px;opacity:0;animation:fadeUp 1s .3s forwards}.hero-title{font-family:var(--font-display);font-size:clamp(40px,7vw,88px);font-weight:800;line-height:1.0;letter-spacing:-.02em;text-transform:uppercase;margin-bottom:28px;opacity:0;animation:fadeUp 1s .5s forwards}.hero-sub{font-size:clamp(15px,1.6vw,18px);font-weight:300;color:var(--gray-light);max-width:580px;margin:0 auto 48px;opacity:0;animation:fadeUp 1s .7s forwards}.hero-ctas{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;opacity:0;animation:fadeUp 1s .9s forwards}.hero-scroll{position:absolute;bottom:40px;left:50%;transform:translateX(-50%);z-index:2;display:flex;flex-direction:column;align-items:center;gap:8px;opacity:0;animation:fadeUp 1s 1.2s forwards}.hero-scroll span{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--gray)}.hero-scroll-line{width:1px;height:40px;background:var(--gold);animation:scrollPulse 2s infinite}@keyframes scrollPulse{0%,100%{opacity:.3;transform:scaleY(.6)}50%{opacity:1;transform:scaleY(1)}}

/* PILLARS */
.pillars{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-top:60px}.pillar{position:relative;height:520px;overflow:hidden;cursor:pointer}.pillar-img{position:absolute;inset:0;background-size:cover;background-position:center;filter:brightness(.4);transition:all .6s}.pillar:hover .pillar-img{filter:brightness(.25);transform:scale(1.05)}.pillar-content{position:relative;z-index:2;height:100%;padding:40px 32px;display:flex;flex-direction:column;justify-content:flex-end}.pillar-number{font-family:var(--font-mono);font-size:11px;letter-spacing:.2em;color:var(--gold);margin-bottom:16px}.pillar-title{font-family:var(--font-display);font-size:clamp(24px,2.5vw,32px);font-weight:400;margin-bottom:12px}.pillar-text{font-size:14px;font-weight:300;color:var(--gray-light);max-width:320px;line-height:1.6;margin-bottom:20px;opacity:0;transform:translateY(10px);transition:all .4s}.pillar:hover .pillar-text{opacity:1;transform:translateY(0)}.pillar-link{font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:var(--gold)}.pillar-link::after{content:' \2192'}

/* SPLIT */
.split{display:grid;grid-template-columns:1fr 1fr;min-height:600px}.split-reverse{direction:rtl}.split-reverse>*{direction:ltr}.split-img{position:relative;overflow:hidden;min-height:500px}.split-img-bg{position:absolute;inset:0;background-size:cover;background-position:center}.split-body{display:flex;flex-direction:column;justify-content:center;padding:clamp(40px,6vw,100px)}

/* TIERS */
.tiers{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:60px}.tier{background:var(--black-card);border:1px solid var(--gray-border);padding:48px 36px;position:relative;transition:all .4s}.tier:hover{border-color:var(--gold)}.tier-featured{border-color:var(--gold)}.tier-featured::before{content:'Le plus populaire';position:absolute;top:0;left:50%;transform:translate(-50%,-50%);font-size:10px;font-weight:500;letter-spacing:.15em;text-transform:uppercase;padding:6px 20px;background:var(--gold);color:var(--black)}.tier-name{font-family:var(--font-display);font-size:28px;font-weight:400;margin-bottom:8px}.tier-price{font-family:var(--font-mono);font-size:13px;color:var(--gold);letter-spacing:.05em;margin-bottom:28px}.tier-desc{font-size:14px;color:var(--gray-light);margin-bottom:32px;line-height:1.6}.tier-features{list-style:none;margin-bottom:40px}.tier-features li{font-size:14px;font-weight:300;color:var(--gray-light);padding:10px 0;border-bottom:1px solid rgba(255,255,255,.05);display:flex;align-items:center;gap:12px}.tier-features li::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--gold);flex-shrink:0}.tier .btn{width:100%;justify-content:center}

/* COACHES */
.coaches{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;margin-top:60px}.coach{position:relative;height:480px;overflow:hidden;cursor:pointer}.coach-img{position:absolute;inset:0;background-size:cover;background-position:center top;filter:brightness(.5) grayscale(.3);transition:all .6s}.coach:hover .coach-img{filter:brightness(.3) grayscale(0);transform:scale(1.05)}.coach-info{position:absolute;bottom:0;left:0;right:0;padding:32px 24px;background:linear-gradient(transparent,rgba(10,10,10,.9))}.coach-name{font-family:var(--font-display);font-size:22px;font-weight:400;margin-bottom:4px}.coach-role{font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:var(--gold);margin-bottom:8px}.coach-bio{font-size:13px;color:var(--gray-light);line-height:1.5;max-height:0;overflow:hidden;transition:max-height .4s}.coach:hover .coach-bio{max-height:80px}

/* EXPERIENCES */
.experiences{display:grid;grid-template-columns:2fr 1fr;gap:2px;margin-top:60px}.experience{position:relative;min-height:500px;overflow:hidden;cursor:pointer}.experience:nth-child(2){grid-row:span 2}.experience-img{position:absolute;inset:0;background-size:cover;background-position:center;filter:brightness(.35);transition:all .6s}.experience:hover .experience-img{filter:brightness(.2);transform:scale(1.05)}.experience-content{position:relative;z-index:2;height:100%;padding:40px;display:flex;flex-direction:column;justify-content:flex-end}.experience-tag{font-family:var(--font-mono);font-size:10px;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);margin-bottom:12px}.experience-title{font-family:var(--font-display);font-size:clamp(22px,2.5vw,34px);font-weight:400;margin-bottom:12px}.experience-desc{font-size:14px;color:var(--gray-light);max-width:400px}

/* PARTNERS */
.partners-grid{display:flex;flex-wrap:wrap;justify-content:center;gap:60px;align-items:center;margin-top:60px;opacity:.5}.partners-grid span{font-family:var(--font-body);font-size:16px;letter-spacing:.15em;text-transform:uppercase;color:var(--gray-light);font-weight:400;transition:opacity .3s;opacity:.6}.partners-grid span:hover{opacity:1}

/* STATS */
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:40px;margin-top:60px}.stat{text-align:center;padding:40px 20px;border:1px solid var(--gray-border)}.stat-number{font-family:var(--font-display);font-size:clamp(36px,4vw,56px);font-weight:300;color:var(--gold);margin-bottom:8px}.stat-label{font-size:13px;letter-spacing:.1em;text-transform:uppercase;color:var(--gray-light)}

/* TESTIMONIAL */
.testimonial{max-width:800px;margin:0 auto;text-align:center;padding:80px 24px}.testimonial-quote{font-family:var(--font-display);font-size:clamp(24px,3vw,36px);font-weight:300;font-style:italic;line-height:1.4;margin-bottom:32px}.testimonial-author{font-size:14px;color:var(--gold);letter-spacing:.1em;text-transform:uppercase}.testimonial-role{font-size:13px;color:var(--gray);margin-top:4px}

/* SCIENCE */
.science-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:32px;margin-top:60px}.science-card{background:var(--black-card);border:1px solid var(--gray-border);padding:40px 32px;transition:border-color .3s}.science-card:hover{border-color:var(--gold)}.science-icon{font-family:var(--font-mono);font-size:11px;color:var(--gold);letter-spacing:.2em;text-transform:uppercase;margin-bottom:20px}.science-card h3{font-family:var(--font-display);font-size:24px;font-weight:400;margin-bottom:12px}.science-card p{font-size:14px;color:var(--gray-light);line-height:1.6}

/* CTA BANNER */
.cta-banner{position:relative;padding:120px clamp(24px,5vw,80px);text-align:center;overflow:hidden}.cta-banner-bg{position:absolute;inset:0;background-size:cover;background-position:center;filter:brightness(.2)}.cta-banner-content{position:relative;z-index:2}.cta-banner .section-title{margin-bottom:20px}.cta-banner .section-desc{margin:0 auto 40px}

/* PAGE HERO (non-home) */
.page-hero{position:relative;height:60vh;min-height:480px;display:flex;align-items:flex-end;padding:clamp(40px,6vw,80px) clamp(24px,5vw,80px);overflow:hidden}.page-hero-bg{position:absolute;inset:0;background-size:cover;background-position:center;filter:brightness(.3) contrast(1.1)}.page-hero-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(10,10,10,.3) 0%,rgba(10,10,10,.85) 100%)}.page-hero-content{position:relative;z-index:2;max-width:800px}

/* FOOTER */
.footer{padding:80px clamp(24px,5vw,80px) 40px;border-top:1px solid rgba(201,169,110,.1)}.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:60px;margin-bottom:60px}.footer-brand{font-family:var(--font-display);font-size:20px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;margin-bottom:16px}.footer-brand span{color:var(--gold)}.footer-tagline{font-size:14px;color:var(--gray);max-width:300px;line-height:1.6}.footer-col-title{font-size:11px;font-weight:500;letter-spacing:.15em;text-transform:uppercase;color:var(--gold);margin-bottom:20px}.footer-col a{display:block;font-size:14px;color:var(--gray-light);margin-bottom:12px;transition:color .3s}.footer-col a:hover{color:var(--white)}.footer-bottom{display:flex;justify-content:space-between;align-items:center;padding-top:32px;border-top:1px solid var(--gray-border);font-size:12px;color:var(--gray)}

/* ANIMATIONS */
@keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}.reveal{opacity:0;transform:translateY(40px);transition:all .8s cubic-bezier(.16,1,.3,1)}.reveal.visible{opacity:1;transform:translateY(0)}

/* RESPONSIVE */
@media(max-width:1024px){.pillars,.tiers,.science-grid{grid-template-columns:1fr}.coaches{grid-template-columns:repeat(2,1fr)}.split{grid-template-columns:1fr}.split-img{min-height:400px}.experiences{grid-template-columns:1fr}.experience:nth-child(2){grid-row:auto}.stats{grid-template-columns:repeat(2,1fr)}.footer-grid{grid-template-columns:1fr 1fr;gap:40px}}@media(max-width:768px){.nav-links{display:none}.nav-hamburger{display:flex}.coaches{grid-template-columns:1fr}.stats{grid-template-columns:1fr;gap:16px}.footer-grid{grid-template-columns:1fr}.footer-bottom{flex-direction:column;gap:12px;text-align:center}}
</style>
</head>
<body>

<nav class="nav" id="main-nav">
  <a href="/" class="nav-logo">No Limit <span>Academy</span></a>
  <div class="nav-links" id="nav-links">
    <a href="/concept" class={currentPath.startsWith('/concept') ? 'active' : ''}>Concept</a>
    <a href="/programmes" class={currentPath.startsWith('/programmes') || currentPath.startsWith('/ascent') || currentPath.startsWith('/summit') || currentPath.startsWith('/legacy') ? 'active' : ''}>Programmes</a>
    <a href="/coachs" class={currentPath.startsWith('/coachs') ? 'active' : ''}>Coachs</a>
    <a href="/experiences" class={currentPath.startsWith('/experiences') ? 'active' : ''}>Experiences</a>
    <a href="/science" class={currentPath.startsWith('/science') ? 'active' : ''}>Science</a>
    <a href="/candidature" class="nav-cta">Postuler</a>
  </div>
  <div class="nav-hamburger" id="hamburger">
    <span></span><span></span><span></span>
  </div>
</nav>

<slot />

<footer class="footer">
  <div class="footer-grid">
    <div>
      <div class="footer-brand">No Limit <span>Academy</span></div>
      <p class="footer-tagline">Coaching d'elite, science preventive et experiences transformationnelles. Concu exclusivement pour les dirigeants visionnaires.</p>
    </div>
    <div class="footer-col">
      <p class="footer-col-title">L'academie</p>
      <a href="/concept">Concept</a>
      <a href="/programmes">Programmes</a>
      <a href="/coachs">Coachs</a>
      <a href="/experiences">Experiences</a>
      <a href="/science">Science</a>
    </div>
    <div class="footer-col">
      <p class="footer-col-title">Postuler</p>
      <a href="/candidature">Devenir membre</a>
      <a href="/candidature">Devenir coach</a>
      <a href="/partenaires">Devenir partenaire</a>
      <a href="/investisseurs">Relations investisseurs</a>
    </div>
    <div class="footer-col">
      <p class="footer-col-title">Nous suivre</p>
      <a href="#">LinkedIn</a>
      <a href="#">Instagram</a>
      <a href="#">YouTube</a>
      <a href="mailto:contact@no-limit-academy.com">Contact</a>
    </div>
  </div>
  <div class="footer-bottom">
    <span>&copy; 2026 No Limit Academy. Tous droits reserves.</span>
    <span>Un projet IKONIK Artisan Creatif</span>
  </div>
</footer>

<script>
const reveals = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver(entries => {
  entries.forEach(el => { if (el.isIntersecting) el.target.classList.add('visible'); });
}, { threshold: 0.1, rootMargin: '0px 0px -60px 0px' });
reveals.forEach(el => observer.observe(el));

window.addEventListener('scroll', () => {
  const nav = document.getElementById('main-nav');
  if (nav) nav.style.background = window.scrollY > 100 ? 'rgba(10,10,10,.95)' : 'rgba(10,10,10,.85)';
});

document.getElementById('hamburger')?.addEventListener('click', () => {
  document.getElementById('nav-links')?.classList.toggle('active');
});

document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', function(e) {
    e.preventDefault();
    const t = document.querySelector((this as HTMLAnchorElement).getAttribute('href') || '');
    if (t) t.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
});
</script>
</body>
</html>
